# GeoRise backend — environment template. Copy to ../.env and fill in.
# NEVER commit the real .env (it is gitignored). Loaded by server.js via dotenv.

# ── Auth (required) ──
# Strong random secret, >= 32 chars. The server refuses to start with a weak one.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# ── OpenAI (optional) ──
# If unset, the app runs fully offline: deterministic mock vision/text + the in-repo
# ONNX litter CNN. Set a key to use real AI.
OPENAI_API_KEY=
ECO_MODEL=gpt-4o-mini
COACH_MODEL=gpt-4o-mini
# Per-request timeout (ms) and retry budget for every OpenAI call.
OPENAI_TIMEOUT_MS=30000
OPENAI_MAX_RETRIES=2

# ── AI Eco Coach ──
# The whole coach surface 404s unless this is exactly "true".
COACH_ENABLED=true
# Eco-action vision confidence floor (0..1) below which a photo is rejected.
ECO_CONFIDENCE_FLOOR=0.3
# Coach faithfulness gate: min lexical support (0..1) to accept a generated question.
COACH_SIM_FLOOR=0.35

# ── Trash detector (offline CNN fallback) ──
TRASH_PROB_THRESHOLD=0.6
# TRASH_MODEL_PATH=./model/trash_detector.onnx

# ── Server ──
PORT=3001
NODE_ENV=development
# Comma-separated allowed origins for CORS (production). Localhost is auto-allowed in dev.
CORS_ORIGINS=
# DATABASE_URL=./georise.db
# AUTH_MAX_PER_WINDOW=30

# ── Demo seed (npm run seed) ──
# Optional fixed demo password; a random one is generated per run if unset.
# DEMO_PASSWORD=
