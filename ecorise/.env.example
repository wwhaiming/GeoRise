# ──────────────────────────────────────────────
# EcoRise — Environment Variables
# Copy this file to .env and fill in values
# ──────────────────────────────────────────────

# Anthropic Claude API (for AI image analysis, quest generation)
ANTHROPIC_API_KEY=

# Claude model used for every vision/text call (override to repoint without code edits)
ECO_MODEL=claude-sonnet-4-6

# Database (SQLite path, defaults to ./ecorise.db)
DATABASE_URL=./ecorise.db

# JWT secret for session tokens — MUST be >= 32 chars or the server refuses to start.
#   generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-random-string-at-least-32-characters-long

# Demo flags (no API key): set to true to let the offline path mint clearly-labeled
# demo results. Leave unset for honest "AI disabled → rejected" behavior.
# MOCK_ECO_ALWAYS_PASS=true
# MOCK_TRASH_ALWAYS_PASS=true

# Cloudinary (optional — for image uploads)
CLOUDINARY_URL=

# Google OAuth (optional — leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Server port
PORT=3001
